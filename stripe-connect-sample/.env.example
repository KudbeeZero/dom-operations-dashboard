# ─────────────────────────────────────────────────────────────────────────────
# Stripe Connect sample — environment configuration
# Copy this file to `.env` and fill in the values, then run `npm start`.
# NEVER commit your real `.env` (it's gitignored).
# ─────────────────────────────────────────────────────────────────────────────

# REQUIRED. Your platform's Stripe SECRET key (starts with sk_test_ for test mode).
# Find it at https://dashboard.stripe.com/apikeys . Without it the app exits with
# a helpful message on startup.
STRIPE_SECRET_KEY=sk_test_REPLACE_ME

# OPTIONAL but recommended. Public base URL the browser can reach this app at.
# Used to build onboarding return/refresh URLs and checkout success/cancel URLs.
# Fine as-is for local dev; in production use your real https domain.
APP_BASE_URL=http://localhost:4242

# OPTIONAL. Signing secret for the CONNECT webhook endpoint (thin V2 events).
# From the webhook destination you create in the Dashboard, or printed by
# `stripe listen` (see the README). Required only to receive webhooks.
CONNECT_WEBHOOK_SECRET=whsec_REPLACE_ME

# OPTIONAL. Port to listen on.
PORT=4242
