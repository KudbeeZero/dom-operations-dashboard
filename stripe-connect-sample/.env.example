# ─────────────────────────────────────────────────────────────────────────────
# Stripe Connect sample — environment configuration
# Copy this file to `.env` and fill in the values, then run `npm start`.
# ─────────────────────────────────────────────────────────────────────────────

# REQUIRED. Your platform's Stripe SECRET key (starts with sk_test_ for test mode).
# Find it at https://dashboard.stripe.com/apikeys . NEVER commit the real value.
STRIPE_SECRET_KEY=sk_test_REPLACE_ME

# OPTIONAL but recommended. Public base URL the browser can reach this app at.
# Used to build onboarding return/refresh URLs and checkout success/cancel URLs.
# For local dev this is fine as-is; in production use your real https domain.
APP_BASE_URL=http://localhost:4242

# OPTIONAL. Price ID for the platform subscription a connected account can buy.
# Create a Price on your PLATFORM account (https://dashboard.stripe.com/products)
# and paste its id (price_...). Leave blank to disable the subscription demo.
PLATFORM_SUBSCRIPTION_PRICE_ID=

# OPTIONAL. Signing secret for the CONNECT webhook endpoint (thin events, V2).
# From the webhook destination you create in the Dashboard, or from `stripe listen`.
CONNECT_WEBHOOK_SECRET=whsec_REPLACE_ME

# OPTIONAL. Signing secret for the SUBSCRIPTION webhook endpoint (snapshot events).
# A separate destination from the Connect one above.
SUBSCRIPTION_WEBHOOK_SECRET=whsec_REPLACE_ME

# OPTIONAL. Port to listen on.
PORT=4242
